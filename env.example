# Red Sea Express Environment Configuration

# Application
APP_NAME=Red Sea Express
APP_ENV=development
APP_PORT=8000

# Database
DATABASE_URL=postgresql://rse_user:rse_password@postgres:5432/redseaexpress
POSTGRES_USER=rse_user
POSTGRES_PASSWORD=rse_password
POSTGRES_DB=redseaexpress

# Backend Security
SECRET_KEY=change_this_secret_key
JWT_SECRET_KEY=change_this_jwt_secret

# Frontend
FRONTEND_URL=http://localhost:3000

# AI Assistant
AI_ASSISTANT_NAME=Aisha AI Assistant
AI_ENABLED=true

# Storage
UPLOAD_DIR=/app/uploads

# Wallet & Payments
WALLET_ENABLED=true
PLATFORM_FEE_PERCENT=5
VENDOR_MARKUP_PERCENT=10

# Logistics
DEFAULT_CURRENCY=USD
DEFAULT_COUNTRY=Yemen
